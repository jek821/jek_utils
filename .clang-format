# Formatting style for all C sources. Applied by `make format` and by
# editors via clangd (the clangd extension reads this file automatically).
# LLVM conventions (attached braces, right-aligned pointers) but with
# 4-space indentation and a 100-column limit.
BasedOnStyle: LLVM
IndentWidth: 4
ColumnLimit: 100
BreakBeforeBraces: Attach
